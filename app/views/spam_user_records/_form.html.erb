<%= turbo_frame_tag "record_form" do %>
  <div class="card mb-4 border-primary">
    <div class="card-header bg-primary text-white">
      <h2 class="h5 mb-0"><%= @record.dn.present? ? "Edit Record" : "Add New Record" %></h2>
    </div>
    <div class="card-body">
      <% form_url = @record.dn.present? ? update_spam_user_records_path : spam_user_records_path %>
      <% form_method = @record.dn.present? ? :put : :post %>

      <%= form_with model: @record, url: form_url, method: form_method, html: { class: "needs-validation", novalidate: true, id: "ldap_record_form" } do |f| %>

        <% if @record.dn.present? %>
          <%= f.hidden_field :dn %>
        <% end %>

        <div class="mb-3">
          <%= f.label :customer_id, "Customer", class: "form-label" %>
          <%= f.select :customer_id, @record.customer_list, { prompt: "Select a Customer" }, class: "form-select", required: true %>
          <div class="invalid-feedback">Please select a customer.</div>
        </div>

        <div class="mb-3">
          <%= f.label :mail, "Email address", class: "form-label" %>
          <%= f.email_field :mail, class: "form-control", required: true %>
          <div class="invalid-feedback">Please provide a valid email address.</div>
        </div>

        <div class="mb-3">
          <%= f.label :uid, "Username", class: "form-label" %>
          <%= f.text_field :uid, class: "form-control", required: true %>
          <div class="invalid-feedback">Username is required.</div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :givenName, "First Name", class: "form-label" %>
            <%= f.text_field :givenName, class: "form-control", required: true %>
            <div class="invalid-feedback">First name is required.</div>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :sn, "Last Name", class: "form-label" %>
            <%= f.text_field :sn, class: "form-control", required: true %>
            <div class="invalid-feedback">Last name is required.</div>
          </div>
        </div>

        <div class="mb-3">
          <%= f.label :fullName, "Full Name", class: "form-label" %>
          <%= f.text_field :fullName, class: "form-control bg-light", readonly: true, required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :ou, "Service Level", class: "form-label" %>
          <%= f.select :ou, @record.service_levels, { prompt: "Select a Service Level" }, class: "form-select", required: true %>
          <div class="invalid-feedback">Please select a service level.</div>
        </div>

        <div class="mt-4 d-flex gap-2">
          <%= f.submit "Save Record", class: "btn btn-success" %>
          <%= link_to "Cancel", spam_user_records_path(customer_id: @record.customer_id), class: "btn btn-outline-secondary", data: { turbo_frame: "_top" } %>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    (function() {
      // 1. Dynamic Full Name Concatenation
      const givenNameInput = document.getElementById('ldap_record_givenName');
      const snInput = document.getElementById('ldap_record_sn');
      const fullNameInput = document.getElementById('ldap_record_fullName');

      const updateFullName = () => {
        const firstName = givenNameInput.value.trim();
        const lastName = snInput.value.trim();

        if (firstName || lastName) {
          fullNameInput.value = `${firstName} ${lastName}`.trim();
        } else {
          fullNameInput.value = '';
        }
      };

      if (givenNameInput && snInput && fullNameInput) {
        givenNameInput.addEventListener('input', updateFullName);
        snInput.addEventListener('input', updateFullName);
      }

      // 2. Bootstrap Validation Handling
      const form = document.getElementById('ldap_record_form');

      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    })();
  </script>
<% end %>