<div class="container mt-5">
  <div id="flash-container">
    <%= render  'shared/flash_messages' %>
  </div>
  <div class="row mb-5">
    <div class="col-md-6">
      <h1 class="text-primary bg-light border p-3">SPAM User Manager</h1>
    </div>
    <div class="col-md-5 text-end">
      <%= form_with url: spam_user_records_path, method: :get, class: "d-inline-block", data: { turbo_frame: "_top" } do |f| %>
        <%= f.select :customer_id,
                     LdapRecord.new.customer_list,
                     { selected: @customer_id, prompt: "Select Customer to View Users" },
                     { class: "form-select", onchange: "this.form.submit()" } %>
      <% end %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-7">
      <% if @customer_id.present? %>
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Users for <%= @customer_id %></h5>
            <%= link_to "Add User", new_spam_user_record_path(customer_id: @customer_id), class: "btn btn-sm btn-primary", data: { turbo_frame: "record_form" } %>
          </div>

          <table class="table table-hover mb-0">
            <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Service Level</th>
              <th>Actions</th>
            </tr>
            </thead>
            <tbody id="spam-users-table_body">
              <%= render partial: "spam_user_row", collection: @records, as: :record %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-muted">Please select a customer from the dropdown above to view users.</p>
      <% end %>
    </div>

    <div class="col-md-5">
      <%= turbo_frame_tag "record_form" do %>
        <div class="p-4 text-center text-muted border rounded bg-light">
          <p class="mb-0">Select an action to load the form.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
