<div class="container mt-4">

  <div id="flash-container">
    <%= render "shared/flash_messages" %>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="text-primary bg-light border p-3">SPAM Customers Manager</h1>
    <%= link_to "Add Customer", new_customer_path, class: "btn btn-success", data: { turbo_frame: "customer_form" } %>
  </div>

  <div class="row mb-5">
    <div class="col-md-7">
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
          <tr>
            <th>ID (OU)</th>
            <th>Customer Name</th>
            <th>MX Record</th>
            <th>Actions</th>
          </tr>
          </thead>
          <tbody id="customers-table-body">
          <%= render partial: "customer_row", collection: @customers, as: :customer %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="col-md-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <%= turbo_frame_tag "customer_form" do %>
            <div class="text-center text-muted p-4">
              <i class="bi bi-building fs-1 d-block mb-2"></i>
              Select an action to load the form.
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>